<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiApp01.Vistas.VistaDemoV"
             Title="VistaDemoV">
    <VerticalStackLayout>
        <Label Text ="LISTA DE MESAS"
                FontAttributes ="Bold"
                FontSize="22"
                HorizontalOptions="Center"
            />
        <Button  Text="CARGAR MESAS"
                 HorizontalOptions="Center"
                 Command="{Binding CargarMesaDTOCommand}"            
            />
        <CollectionView ItemsSource="{Binding ListaMesasDTO}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1" 
                            Stroke="LightGray" Padding="15"
                            Margin="0,5"
                            StrokeShape="RoundRectangle 4"
                            BackgroundColor="{Binding NombreColor}">
                        <StackLayout>
                            <Label Text="{Binding NumeroMesa}" FontSize="18" TextColor="White"/>
                            <Label Text="{Binding EstadoMesa}" FontSize="14" TextColor="White"/>
                            <Label Text="{Binding CapacidadMesa}" FontSize="12" TextColor="White"/>
                        </StackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>